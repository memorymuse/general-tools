# Disk space check function
disk_check() {
    usage=$(df / | tail -1 | awk '{print $5}' | sed 's/%//')
    if [ $usage -gt 85 ]; then
        echo "🚨 DISK USAGE CRITICAL: ${usage}% 🚨"
        echo "Running emergency cleanup..."
        ~/cleanup_ai_cache.sh
    fi
}

# Check disk space before large downloads
check_space() {
    available=$(df / | tail -1 | awk '{print $4}')
    if [ $available -lt 10000000 ]; then  # Less than 10GB
        echo "WARNING: Less than 10GB available. Clean cache first\!"
        ~/cleanup_ai_cache.sh
    fi
}


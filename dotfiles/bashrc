# ============================================
# Claude Code + direnv Integration
# ============================================
# Automatically loads direnv environment variables before launching Claude Code
# This enables hierarchical env var loading: user-level → project → stream → flow
claude() {
    if eval "$(direnv export bash)"; then
        sleep 1.5  # Force 1.5 second pause to read direnv output
        command claude "$@"
    else
        # direnv already printed its errors above
        echo "" >&2
        echo "⚠️  Claude Code not launched due to errors above." >&2
        return 1
    fi
}

# Auto-approve Claude Code (skips permissions prompts)
autocc() {
    local first_arg="$1"

    if [[ "$first_arg" == "continue" || "$first_arg" == "cont" || "$first_arg" == "c" ]]; then
        shift  # Remove the continue/cont/c argument
        claude --dangerously-skip-permissions --continue "$@"
    else
        claude --dangerously-skip-permissions "$@"
    fi
}

# Allow all .envrc files in current directory and below
direnv-allow-all() {
    local count=0
    echo "Searching for .envrc files in $(pwd) and subdirectories..."

    while IFS= read -r envrc_file; do
        local dir=$(dirname "$envrc_file")
        echo "  ✓ Allowing: $dir"
        direnv allow "$dir"
        ((count++))
    done < <(find . -name ".envrc" -type f)

    echo ""
    echo "Allowed $count .envrc file(s)"
}


{
  "permissions": {
    "defaultMode": "dontAsk"
  },
  "alwaysThinkingEnabled": true,
  "enabledPlugins": {
    "taches-cc-resources@taches-cc-resources": true
  },
  "hooks": {
    "SubagentStop": [
      {
        "matcher": "self-review-p5-verify",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/self-review-logger.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}

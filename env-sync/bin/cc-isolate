#!/usr/bin/env bash
#
# cc-isolate - Claude Code Isolation System
# Manages isolated bash environments for Claude Code with cross-platform support
#

set -euo pipefail

# Version
VERSION="1.0.0"

# Determine script directory (works on macOS and Linux)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV_SYNC_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Import platform detection library
source "$ENV_SYNC_ROOT/lib/platform.sh"

# Configuration
CONFIG_FILE="${CC_ISOLATE_CONFIG:-$ENV_SYNC_ROOT/config.sh}"
STATE_FILE="$ENV_SYNC_ROOT/.state"

# Colors for output
if [[ -t 1 ]]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    BLUE='\033[0;34m'
    MAGENTA='\033[0;35m'
    CYAN='\033[0;36m'
    BOLD='\033[1m'
    RESET='\033[0m'
else
    RED='' GREEN='' YELLOW='' BLUE='' MAGENTA='' CYAN='' BOLD='' RESET=''
fi

# Load configuration if exists
if [[ -f "$CONFIG_FILE" ]]; then
    source "$CONFIG_FILE"
fi

# Default configuration values
SYSTEM_BASHRC="${SYSTEM_BASHRC:-$(get_system_bashrc)}"
CC_BASHRC="${CC_BASHRC:-$ENV_SYNC_ROOT/profiles/global/bashrc}"
PROTECT_SYSTEM_BASHRC="${PROTECT_SYSTEM_BASHRC:-true}"
DOTFILE_SYNC_MODE="${DOTFILE_SYNC_MODE:-list}"
DOTFILES_TO_SYNC="${DOTFILES_TO_SYNC:-.gitconfig .vimrc .tmux.conf}"

#------------------------------------------------------------------------------
# Helper Functions
#------------------------------------------------------------------------------

print_header() {
    echo -e "${BLUE}${BOLD}╔══════════════════════════════════════════════════════════╗${RESET}"
    echo -e "${BLUE}${BOLD}║${RESET}  ${CYAN}cc-isolate${RESET} v${VERSION} - Claude Code Isolation System  ${BLUE}${BOLD}║${RESET}"
    echo -e "${BLUE}${BOLD}╚══════════════════════════════════════════════════════════╝${RESET}"
    echo
}

log_info() {
    echo -e "${BLUE}ℹ${RESET} $*"
}

log_success() {
    echo -e "${GREEN}✓${RESET} $*"
}

log_warn() {
    echo -e "${YELLOW}⚠${RESET} $*"
}

log_error() {
    echo -e "${RED}✗${RESET} $*" >&2
}

die() {
    log_error "$*"
    exit 1
}

# Get current isolation state
get_state() {
    local key="$1"
    if [[ -f "$STATE_FILE" ]]; then
        grep "^${key}=" "$STATE_FILE" 2>/dev/null | cut -d= -f2-
    fi
}

# Set state
set_state() {
    local key="$1"
    local value="$2"

    # Create state file if doesn't exist
    touch "$STATE_FILE"

    # Update or add the key
    if grep -q "^${key}=" "$STATE_FILE" 2>/dev/null; then
        sed -i.bak "s|^${key}=.*|${key}=${value}|" "$STATE_FILE"
        rm -f "${STATE_FILE}.bak"
    else
        echo "${key}=${value}" >> "$STATE_FILE"
    fi
}

# Check if currently mounted
is_mounted() {
    [[ "$(get_state MOUNTED)" == "true" ]]
}

# Get current profile
get_current_profile() {
    local profile=$(get_state CURRENT_PROFILE)
    echo "${profile:-global}"
}

#------------------------------------------------------------------------------
# Protection Functions
#------------------------------------------------------------------------------

protect_file() {
    local file="$1"

    if [[ ! -f "$file" ]]; then
        log_warn "File does not exist: $file"
        return 1
    fi

    log_info "Protecting file: $file"

    if is_linux; then
        # Use chattr on Linux
        if command -v chattr >/dev/null 2>&1; then
            if sudo chattr +i "$file" 2>/dev/null; then
                log_success "File protected with immutable flag (chattr +i)"
                return 0
            else
                log_warn "Failed to set immutable flag. Continuing anyway."
                return 1
            fi
        else
            log_warn "chattr not available. File protection skipped."
            return 1
        fi
    elif is_macos; then
        # Use chflags on macOS
        if sudo chflags uchg "$file" 2>/dev/null; then
            log_success "File protected with user immutable flag (chflags uchg)"
            return 0
        else
            log_warn "Failed to set immutable flag. Continuing anyway."
            return 1
        fi
    else
        log_warn "Unknown platform. File protection skipped."
        return 1
    fi
}

unprotect_file() {
    local file="$1"

    if [[ ! -f "$file" ]]; then
        return 0
    fi

    log_info "Unprotecting file: $file"

    if is_linux; then
        if command -v chattr >/dev/null 2>&1; then
            sudo chattr -i "$file" 2>/dev/null || true
            log_success "File unprotected (chattr -i)"
        fi
    elif is_macos; then
        sudo chflags nouchg "$file" 2>/dev/null || true
        log_success "File unprotected (chflags nouchg)"
    fi
}

#------------------------------------------------------------------------------
# Mount/Unmount Functions
#------------------------------------------------------------------------------

cmd_mount() {
    local profile="${1:-global}"

    print_header
    log_info "Mounting CC isolation (profile: ${BOLD}${profile}${RESET})"
    echo

    # Check if already mounted
    if is_mounted; then
        local current_profile=$(get_current_profile)
        if [[ "$current_profile" == "$profile" ]]; then
            log_warn "Already mounted with profile: $profile"
            return 0
        else
            log_info "Switching from profile '$current_profile' to '$profile'"
            cmd_unmount
        fi
    fi

    # Validate profile exists
    local profile_dir="$ENV_SYNC_ROOT/profiles/$profile"
    if [[ ! -d "$profile_dir" ]]; then
        die "Profile not found: $profile\nAvailable profiles: $(list_profiles)"
    fi

    # Backup system bashrc if it exists and we haven't backed it up
    if [[ -f "$SYSTEM_BASHRC" ]] && [[ ! -f "$ENV_SYNC_ROOT/system-backup/bashrc.backup" ]]; then
        log_info "Backing up system bashrc: $SYSTEM_BASHRC"
        cp "$SYSTEM_BASHRC" "$ENV_SYNC_ROOT/system-backup/bashrc.backup"
        log_success "Backup created"
    fi

    # Protect system bashrc if configured
    if [[ "$PROTECT_SYSTEM_BASHRC" == "true" ]] && [[ -f "$SYSTEM_BASHRC" ]]; then
        protect_file "$SYSTEM_BASHRC"
    fi

    # Set environment variable for CC to use our bashrc
    log_info "Setting up isolated bashrc: $profile_dir/bashrc"

    # Create shell configuration
    cat > "$ENV_SYNC_ROOT/.cc-env" << EOF
# CC-Isolate Environment
# This file is sourced by Claude Code sessions
# Generated: $(date)
# Profile: $profile

# Source system bashrc first (if it exists and is readable)
if [[ -f "$SYSTEM_BASHRC" ]] && [[ -r "$SYSTEM_BASHRC" ]]; then
    source "$SYSTEM_BASHRC"
fi

# Source CC-specific bashrc (our customizations override system settings)
if [[ -f "$profile_dir/bashrc" ]]; then
    source "$profile_dir/bashrc"
fi

# Source any additional snippets from bashrc.d
if [[ -d "$ENV_SYNC_ROOT/bashrc.d" ]]; then
    for script in "$ENV_SYNC_ROOT/bashrc.d"/*.sh; do
        if [[ -r "\$script" ]]; then
            source "\$script"
        fi
    done
fi

export CC_ISOLATE_ACTIVE=true
export CC_ISOLATE_PROFILE="$profile"
EOF

    log_success "Isolated environment configured"

    # Update state
    set_state MOUNTED true
    set_state CURRENT_PROFILE "$profile"
    set_state MOUNT_TIME "$(date -Iseconds)"

    echo
    log_success "${BOLD}Isolation mounted successfully!${RESET}"
    echo
    log_info "To activate in your current shell, run:"
    echo -e "  ${CYAN}source $ENV_SYNC_ROOT/.cc-env${RESET}"
    echo
    log_info "To automatically use this for Claude Code:"
    echo -e "  ${CYAN}export BASH_ENV=$ENV_SYNC_ROOT/.cc-env${RESET}"
    echo -e "  ${CYAN}# Add the above to your shell profile for persistence${RESET}"
    echo
}

cmd_unmount() {
    print_header
    log_info "Unmounting CC isolation"
    echo

    if ! is_mounted; then
        log_warn "Not currently mounted"
        return 0
    fi

    # Unprotect system bashrc
    if [[ -f "$SYSTEM_BASHRC" ]]; then
        unprotect_file "$SYSTEM_BASHRC"
    fi

    # Remove CC environment file
    if [[ -f "$ENV_SYNC_ROOT/.cc-env" ]]; then
        rm -f "$ENV_SYNC_ROOT/.cc-env"
        log_success "Removed isolated environment"
    fi

    # Update state
    set_state MOUNTED false
    set_state UNMOUNT_TIME "$(date -Iseconds)"

    echo
    log_success "${BOLD}Isolation unmounted successfully!${RESET}"
    echo
    log_info "Remember to unset BASH_ENV if you set it:"
    echo -e "  ${CYAN}unset BASH_ENV${RESET}"
    echo
}

#------------------------------------------------------------------------------
# Status Functions
#------------------------------------------------------------------------------

cmd_status() {
    print_header

    local mounted=$(is_mounted && echo "Yes" || echo "No")
    local profile=$(get_current_profile)
    local mount_time=$(get_state MOUNT_TIME)

    echo -e "${BOLD}Isolation Status:${RESET}"
    echo -e "  Mounted:        ${mounted}"
    if is_mounted; then
        echo -e "  Profile:        ${CYAN}${profile}${RESET}"
        echo -e "  Mounted at:     ${mount_time}"
        echo -e "  Env file:       ${CC_BASHRC}"

        if [[ -n "${BASH_ENV:-}" ]]; then
            echo -e "  BASH_ENV:       ${GREEN}${BASH_ENV}${RESET}"
        else
            echo -e "  BASH_ENV:       ${YELLOW}Not set${RESET}"
        fi
    fi

    echo
    echo -e "${BOLD}System Information:${RESET}"
    echo -e "  Platform:       $(get_platform_name)"
    echo -e "  System bashrc:  ${SYSTEM_BASHRC}"
    echo -e "  Protection:     ${PROTECT_SYSTEM_BASHRC}"

    echo
    echo -e "${BOLD}Configuration:${RESET}"
    echo -e "  Root:           ${ENV_SYNC_ROOT}"
    echo -e "  Config:         ${CONFIG_FILE}"
    echo -e "  Dotfile sync:   ${DOTFILE_SYNC_MODE}"

    echo
    echo -e "${BOLD}Available Profiles:${RESET}"
    list_profiles | sed 's/^/  /'

    echo
}

#------------------------------------------------------------------------------
# Profile Management
#------------------------------------------------------------------------------

list_profiles() {
    local profiles_dir="$ENV_SYNC_ROOT/profiles"

    for profile_path in "$profiles_dir"/*; do
        if [[ -d "$profile_path" ]]; then
            local profile_name=$(basename "$profile_path")
            local current=$(get_current_profile)

            if [[ "$profile_name" == "$current" ]] && is_mounted; then
                echo -e "${GREEN}●${RESET} ${BOLD}${profile_name}${RESET} (active)"
            else
                echo -e "  ${profile_name}"
            fi
        fi
    done
}

cmd_profile_list() {
    print_header
    echo -e "${BOLD}Available Profiles:${RESET}"
    echo
    list_profiles
    echo
}

cmd_profile_create() {
    local profile_name="$1"

    if [[ -z "$profile_name" ]]; then
        die "Usage: cc-isolate profile create <profile-name>"
    fi

    local profile_dir="$ENV_SYNC_ROOT/profiles/$profile_name"

    if [[ -d "$profile_dir" ]]; then
        die "Profile already exists: $profile_name"
    fi

    print_header
    log_info "Creating profile: $profile_name"

    mkdir -p "$profile_dir"

    # Create bashrc template
    cat > "$profile_dir/bashrc" << 'EOF'
#!/usr/bin/env bash
#
# CC-Isolate Profile Bashrc
# This file is sourced AFTER the system bashrc
# Settings here override system settings
#

# Example: Set a custom prompt for CC sessions
# PS1='\[\033[01;35m\][CC]\[\033[00m\] \[\033[01;34m\]\w\[\033[00m\]\$ '

# Example: Add custom aliases
# alias ll='ls -lah'

# Example: Add to PATH
# export PATH="$HOME/bin:$PATH"

# Example: Set environment variables
# export EDITOR=vim

# Add your customizations below:
EOF

    log_success "Profile created: $profile_dir"
    log_info "Edit the bashrc at: $profile_dir/bashrc"
    echo
}

cmd_profile_delete() {
    local profile_name="$1"

    if [[ -z "$profile_name" ]]; then
        die "Usage: cc-isolate profile delete <profile-name>"
    fi

    if [[ "$profile_name" == "global" ]]; then
        die "Cannot delete the global profile"
    fi

    local profile_dir="$ENV_SYNC_ROOT/profiles/$profile_name"

    if [[ ! -d "$profile_dir" ]]; then
        die "Profile not found: $profile_name"
    fi

    # Check if it's the active profile
    if is_mounted && [[ "$(get_current_profile)" == "$profile_name" ]]; then
        die "Cannot delete active profile. Unmount first."
    fi

    print_header
    log_warn "Deleting profile: $profile_name"
    read -p "Are you sure? [y/N] " -n 1 -r
    echo

    if [[ $REPLY =~ ^[Yy]$ ]]; then
        rm -rf "$profile_dir"
        log_success "Profile deleted: $profile_name"
    else
        log_info "Cancelled"
    fi
    echo
}

#------------------------------------------------------------------------------
# Dotfile Sync
#------------------------------------------------------------------------------

cmd_dotfiles_sync() {
    print_header
    log_info "Syncing dotfiles (mode: $DOTFILE_SYNC_MODE)"
    echo

    local dotfiles_dir="$ENV_SYNC_ROOT/dotfiles"
    local synced=0
    local skipped=0

    case "$DOTFILE_SYNC_MODE" in
        none)
            log_info "Dotfile sync disabled (mode: none)"
            return 0
            ;;

        list)
            for dotfile in $DOTFILES_TO_SYNC; do
                sync_dotfile "$dotfile" && ((synced++)) || ((skipped++))
            done
            ;;

        all)
            # Sync all dotfiles in the dotfiles directory
            for dotfile_path in "$dotfiles_dir"/.*; do
                local dotfile=$(basename "$dotfile_path")
                # Skip . and ..
                [[ "$dotfile" == "." || "$dotfile" == ".." ]] && continue

                sync_dotfile "$dotfile" && ((synced++)) || ((skipped++))
            done
            ;;

        *)
            die "Unknown dotfile sync mode: $DOTFILE_SYNC_MODE"
            ;;
    esac

    echo
    log_success "Sync complete: $synced synced, $skipped skipped"
    echo
}

sync_dotfile() {
    local dotfile="$1"
    local home_file="$HOME/$dotfile"
    local repo_file="$ENV_SYNC_ROOT/dotfiles/$dotfile"

    # If file doesn't exist in repo, copy from home
    if [[ ! -f "$repo_file" ]] && [[ -f "$home_file" ]]; then
        log_info "Importing to repo: $dotfile"
        cp "$home_file" "$repo_file"
        log_success "Imported: $dotfile"
        return 0
    fi

    # If file exists in repo but not in home, create symlink
    if [[ -f "$repo_file" ]] && [[ ! -e "$home_file" ]]; then
        log_info "Creating symlink: $dotfile"
        ln -sf "$repo_file" "$home_file"
        log_success "Linked: $dotfile"
        return 0
    fi

    # If both exist and home is not a symlink, ask what to do
    if [[ -f "$repo_file" ]] && [[ -f "$home_file" ]] && [[ ! -L "$home_file" ]]; then
        log_warn "Conflict: $dotfile exists in both locations"
        # For now, skip. Could add interactive resolution later
        return 1
    fi

    # If home is already a symlink to repo, nothing to do
    if [[ -L "$home_file" ]] && [[ "$(readlink "$home_file")" == "$repo_file" ]]; then
        return 0
    fi

    log_warn "Skipped: $dotfile"
    return 1
}

#------------------------------------------------------------------------------
# Main Command Dispatcher
#------------------------------------------------------------------------------

cmd_help() {
    print_header
    cat << EOF
${BOLD}USAGE:${RESET}
  cc-isolate <command> [options]

${BOLD}COMMANDS:${RESET}
  ${CYAN}mount [profile]${RESET}      Mount CC isolation (default: global)
  ${CYAN}unmount${RESET}               Unmount CC isolation
  ${CYAN}status${RESET}                Show isolation status

  ${CYAN}profile list${RESET}          List available profiles
  ${CYAN}profile create <name>${RESET} Create a new profile
  ${CYAN}profile delete <name>${RESET} Delete a profile

  ${CYAN}dotfiles sync${RESET}         Sync dotfiles locally (create symlinks)
  ${CYAN}dotfiles list${RESET}         List managed dotfiles
  ${CYAN}dotfiles push [msg]${RESET}   Commit and push dotfiles to GitHub
  ${CYAN}dotfiles pull${RESET}         Pull dotfiles from GitHub and re-sync

  ${CYAN}sync push [msg]${RESET}       Push all changes to GitHub
  ${CYAN}sync pull${RESET}             Pull all changes from GitHub
  ${CYAN}sync status${RESET}           Show git repository status

  ${CYAN}config${RESET}                Show current configuration
  ${CYAN}help${RESET}                  Show this help message
  ${CYAN}version${RESET}               Show version

${BOLD}EXAMPLES:${RESET}
  # Mount global isolation
  cc-isolate mount

  # Mount project-specific isolation
  cc-isolate mount my-project

  # Check status
  cc-isolate status

  # Sync dotfiles locally
  cc-isolate dotfiles sync

  # Push dotfiles to GitHub
  cc-isolate dotfiles push "Update gitconfig"

  # Pull everything from GitHub
  cc-isolate sync pull

  # Check what needs to be pushed
  cc-isolate sync status

  # Create a new profile
  cc-isolate profile create web-dev

${BOLD}FILES:${RESET}
  Config:       $CONFIG_FILE
  State:        $STATE_FILE
  Profiles:     $ENV_SYNC_ROOT/profiles/
  Dotfiles:     $ENV_SYNC_ROOT/dotfiles/

${BOLD}ENVIRONMENT:${RESET}
  CC_ISOLATE_CONFIG    Path to config file
  BASH_ENV             Set to $ENV_SYNC_ROOT/.cc-env for CC sessions

For more information, see: $ENV_SYNC_ROOT/README.md
EOF
}

cmd_config() {
    print_header
    echo -e "${BOLD}Current Configuration:${RESET}"
    echo
    echo "SYSTEM_BASHRC=$SYSTEM_BASHRC"
    echo "CC_BASHRC=$CC_BASHRC"
    echo "PROTECT_SYSTEM_BASHRC=$PROTECT_SYSTEM_BASHRC"
    echo "DOTFILE_SYNC_MODE=$DOTFILE_SYNC_MODE"
    echo "DOTFILES_TO_SYNC=$DOTFILES_TO_SYNC"
    echo
    echo -e "${BOLD}Config file:${RESET} $CONFIG_FILE"
    echo
}

cmd_version() {
    echo "cc-isolate version $VERSION"
}

cmd_dotfiles_list() {
    print_header
    echo -e "${BOLD}Managed Dotfiles:${RESET}"
    echo

    local dotfiles_dir="$ENV_SYNC_ROOT/dotfiles"

    if [[ ! -d "$dotfiles_dir" ]]; then
        log_warn "Dotfiles directory not found"
        return 1
    fi

    for dotfile_path in "$dotfiles_dir"/.*; do
        local dotfile=$(basename "$dotfile_path")
        [[ "$dotfile" == "." || "$dotfile" == ".." ]] && continue

        local home_file="$HOME/$dotfile"

        if [[ -L "$home_file" ]] && [[ "$(readlink "$home_file")" == "$dotfile_path" ]]; then
            echo -e "  ${GREEN}●${RESET} $dotfile ${CYAN}(linked)${RESET}"
        elif [[ -f "$home_file" ]]; then
            echo -e "  ${YELLOW}○${RESET} $dotfile ${YELLOW}(conflict)${RESET}"
        else
            echo -e "  ${BLUE}○${RESET} $dotfile ${BLUE}(not linked)${RESET}"
        fi
    done
    echo
}

#------------------------------------------------------------------------------
# Git Sync Functions
#------------------------------------------------------------------------------

# Check if we're in a git repository
check_git_repo() {
    if ! git -C "$ENV_SYNC_ROOT" rev-parse --git-dir >/dev/null 2>&1; then
        die "Not a git repository. Cannot sync."
    fi
}

# Get modified files in specific directories
get_modified_files() {
    local paths=("$@")
    git -C "$ENV_SYNC_ROOT" status --porcelain "${paths[@]}" 2>/dev/null || true
}

cmd_dotfiles_push() {
    print_header
    check_git_repo

    local message="${1:-Update dotfiles}"

    log_info "Pushing dotfiles to remote repository"
    echo

    # Check if there are changes in dotfiles
    cd "$ENV_SYNC_ROOT"

    local changes=$(get_modified_files "dotfiles/")

    if [[ -z "$changes" ]]; then
        log_info "No changes to push in dotfiles/"
        return 0
    fi

    log_info "Changes detected:"
    echo "$changes" | sed 's/^/  /'
    echo

    # Add dotfiles
    log_info "Staging dotfiles..."
    git add dotfiles/
    log_success "Staged"

    # Commit
    log_info "Committing changes..."
    git commit -m "$message"
    log_success "Committed"

    # Push
    log_info "Pushing to remote..."
    if git push; then
        log_success "Pushed to remote"
        echo
        log_success "${BOLD}Dotfiles synced to repository!${RESET}"
    else
        log_error "Failed to push to remote"
        return 1
    fi
    echo
}

cmd_dotfiles_pull() {
    print_header
    check_git_repo

    log_info "Pulling dotfiles from remote repository"
    echo

    cd "$ENV_SYNC_ROOT"

    # Check for uncommitted changes
    if ! git diff-index --quiet HEAD -- dotfiles/ 2>/dev/null; then
        log_warn "You have uncommitted changes in dotfiles/"
        read -p "Stash changes and pull? [y/N] " -n 1 -r
        echo
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            log_info "Stashing changes..."
            git stash push -m "cc-isolate: Auto-stash before pull" dotfiles/
            log_success "Changes stashed"
        else
            log_error "Cannot pull with uncommitted changes"
            return 1
        fi
    fi

    # Pull
    log_info "Pulling from remote..."
    if git pull; then
        log_success "Pulled from remote"
        echo

        # Re-sync dotfiles
        log_info "Re-syncing dotfiles..."
        cmd_dotfiles_sync

        log_success "${BOLD}Dotfiles synced from repository!${RESET}"
    else
        log_error "Failed to pull from remote"
        return 1
    fi
    echo
}

cmd_sync_push() {
    print_header
    check_git_repo

    local message="${1:-Update cc-isolate environment}"

    log_info "Pushing environment to remote repository"
    echo

    cd "$ENV_SYNC_ROOT"

    # Check for changes in key directories
    local changes=$(get_modified_files "dotfiles/" "profiles/" "bashrc.d/" "config.sh")

    if [[ -z "$changes" ]]; then
        log_info "No changes to push"
        return 0
    fi

    log_info "Changes detected:"
    echo "$changes" | sed 's/^/  /'
    echo

    # Add all relevant files
    log_info "Staging changes..."
    git add dotfiles/ profiles/ bashrc.d/ config.sh 2>/dev/null || true
    log_success "Staged"

    # Commit
    log_info "Committing changes..."
    if git commit -m "$message"; then
        log_success "Committed"

        # Push
        log_info "Pushing to remote..."
        if git push; then
            log_success "Pushed to remote"
            echo
            log_success "${BOLD}Environment synced to repository!${RESET}"
        else
            log_error "Failed to push to remote"
            return 1
        fi
    else
        log_warn "No changes to commit (already up to date)"
    fi
    echo
}

cmd_sync_pull() {
    print_header
    check_git_repo

    log_info "Pulling environment from remote repository"
    echo

    cd "$ENV_SYNC_ROOT"

    # Check for uncommitted changes
    local dirs=("dotfiles/" "profiles/" "bashrc.d/" "config.sh")
    local has_changes=false

    for dir in "${dirs[@]}"; do
        if ! git diff-index --quiet HEAD -- "$dir" 2>/dev/null; then
            has_changes=true
            break
        fi
    done

    if $has_changes; then
        log_warn "You have uncommitted changes"
        read -p "Stash changes and pull? [y/N] " -n 1 -r
        echo
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            log_info "Stashing changes..."
            git stash push -m "cc-isolate: Auto-stash before pull" "${dirs[@]}"
            log_success "Changes stashed"
        else
            log_error "Cannot pull with uncommitted changes"
            return 1
        fi
    fi

    # Pull
    log_info "Pulling from remote..."
    if git pull; then
        log_success "Pulled from remote"
        echo

        # Re-sync dotfiles
        log_info "Re-syncing dotfiles..."
        cmd_dotfiles_sync

        # Reload config
        if [[ -f "$CONFIG_FILE" ]]; then
            source "$CONFIG_FILE"
            log_success "Reloaded configuration"
        fi

        # If mounted, suggest remount
        if is_mounted; then
            echo
            log_warn "Isolation is currently mounted"
            log_info "Consider remounting to apply changes:"
            echo -e "  ${CYAN}cc-isolate unmount && cc-isolate mount$(get_current_profile)${RESET}"
        fi

        echo
        log_success "${BOLD}Environment synced from repository!${RESET}"
    else
        log_error "Failed to pull from remote"
        return 1
    fi
    echo
}

cmd_sync_status() {
    print_header
    check_git_repo

    cd "$ENV_SYNC_ROOT"

    echo -e "${BOLD}Git Repository Status:${RESET}"
    echo

    # Show current branch
    local branch=$(git branch --show-current 2>/dev/null || echo "unknown")
    echo -e "  Branch:         ${CYAN}${branch}${RESET}"

    # Show remote
    local remote=$(git remote get-url origin 2>/dev/null || echo "none")
    echo -e "  Remote:         ${remote}"

    # Show last commit
    local last_commit=$(git log -1 --format="%h - %s (%ar)" 2>/dev/null || echo "none")
    echo -e "  Last commit:    ${last_commit}"

    echo
    echo -e "${BOLD}Pending Changes:${RESET}"
    echo

    # Check for changes
    local changes=$(get_modified_files "dotfiles/" "profiles/" "bashrc.d/" "config.sh")

    if [[ -z "$changes" ]]; then
        log_success "No pending changes"
    else
        echo "$changes" | while IFS= read -r line; do
            local status="${line:0:2}"
            local file="${line:3}"

            case "$status" in
                "M ")
                    echo -e "  ${YELLOW}M${RESET}  $file"
                    ;;
                "A ")
                    echo -e "  ${GREEN}A${RESET}  $file"
                    ;;
                "D ")
                    echo -e "  ${RED}D${RESET}  $file"
                    ;;
                "??")
                    echo -e "  ${BLUE}?${RESET}  $file"
                    ;;
                *)
                    echo -e "     $file"
                    ;;
            esac
        done

        echo
        log_info "To push changes: ${CYAN}cc-isolate sync push${RESET}"
    fi
    echo
}

#------------------------------------------------------------------------------
# Main Entry Point
#------------------------------------------------------------------------------

main() {
    local command="${1:-help}"
    shift || true

    case "$command" in
        mount)
            cmd_mount "$@"
            ;;
        unmount)
            cmd_unmount
            ;;
        status)
            cmd_status
            ;;
        profile)
            local subcommand="${1:-list}"
            shift || true
            case "$subcommand" in
                list)
                    cmd_profile_list
                    ;;
                create)
                    cmd_profile_create "$@"
                    ;;
                delete)
                    cmd_profile_delete "$@"
                    ;;
                *)
                    die "Unknown profile command: $subcommand"
                    ;;
            esac
            ;;
        dotfiles)
            local subcommand="${1:-sync}"
            shift || true
            case "$subcommand" in
                sync)
                    cmd_dotfiles_sync
                    ;;
                list)
                    cmd_dotfiles_list
                    ;;
                push)
                    cmd_dotfiles_push "$@"
                    ;;
                pull)
                    cmd_dotfiles_pull
                    ;;
                *)
                    die "Unknown dotfiles command: $subcommand"
                    ;;
            esac
            ;;
        sync)
            local subcommand="${1:-status}"
            shift || true
            case "$subcommand" in
                push)
                    cmd_sync_push "$@"
                    ;;
                pull)
                    cmd_sync_pull
                    ;;
                status)
                    cmd_sync_status
                    ;;
                *)
                    die "Unknown sync command: $subcommand"
                    ;;
            esac
            ;;
        config)
            cmd_config
            ;;
        help|--help|-h)
            cmd_help
            ;;
        version|--version|-v)
            cmd_version
            ;;
        *)
            log_error "Unknown command: $command"
            echo
            cmd_help
            exit 1
            ;;
    esac
}

# Run main
main "$@"

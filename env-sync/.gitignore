# CC-Isolate Generated Files
.state
.cc-env
system-backup/
.cc-secrets-whitelist

# Test artifacts
.cc-test-*
tests/fixtures/*.test

# OS Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Editor Files
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# Logs
*.log

# Temporary files
*.tmp
*.bak
*.backup

# Secret files (never commit these!)
*.env
*.env.local
*.env.production
*.env.development
.aws/credentials
.npmrc
id_rsa
id_dsa
id_ecdsa
id_ed25519
*.pem
*.key
*.p12
*.pfx

# Don't ignore example/template files
!dotfiles/.gitconfig.example
!dotfiles/*.example
!dotfiles/*.template
!**/*.template
!**/*.example
